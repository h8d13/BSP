#!/bin/bash
# extract — Decompress a specific .img.gz or .img.xz from out/ into out_extract/ with progress
set -euo pipefail

readonly PROGNAME="${0##*/}"
script_dir="$(cd "$(dirname "$0")" && pwd)"

src_dir="${script_dir}/out"
dst_dir="${script_dir}/out_extract"

# ── Colours ───────────────────────────────────────────────────────────────
if [[ -t 1 ]]; then
    B='\033[1m'; R='\033[0m'; RED='\033[1;31m'; GRN='\033[1;32m'; CYN='\033[1;36m'
else
    B=''; R=''; RED=''; GRN=''; CYN=''
fi

_msg()  { printf "${CYN}[${PROGNAME}]${R} %s\n" "$*"; }
_ok()   { printf "${GRN}[${PROGNAME}] ✓${R} %s\n" "$*"; }
_die()  { printf "${RED}[${PROGNAME}] ✗${R} %s\n" "$*" >&2; exit 1; }

_usage() {
    cat <<EOF
${B}${PROGNAME}${R} — Extract compressed .img with progress

${B}Usage:${R}
    ${PROGNAME} <image-name>

${B}Example:${R}
    ${PROGNAME} archlinux-g5-ppc64-20260222.img.gz
    ${PROGNAME} archlinux-g5-ppc64-20260222.img.xz
    ${PROGNAME} archlinux-g5-ppc64-20260222     # extension auto-detected

Decompresses out/<image> into out_extract/ with a progress bar.
EOF
    exit "${1:-0}"
}

# ── Argument parsing ──────────────────────────────────────────────────────
[[ $# -ge 1 ]] || _usage 1
[[ "$1" == "-h" || "$1" == "--help" ]] && _usage 0

input="$1"

# Resolve image path — try exact match, then .img.gz, then .img.xz
if [[ "${input}" == *.img.gz || "${input}" == *.img.xz ]]; then
    img="${src_dir}/${input}"
elif [[ "${input}" == *.img ]]; then
    # Try gz first, then xz
    if [[ -f "${src_dir}/${input}.gz" ]]; then
        img="${src_dir}/${input}.gz"
    else
        img="${src_dir}/${input}.xz"
    fi
else
    if [[ -f "${src_dir}/${input}.img.gz" ]]; then
        img="${src_dir}/${input}.img.gz"
    else
        img="${src_dir}/${input}.img.xz"
    fi
fi

[[ -f "${img}" ]] || _die "Not found: ${img} (looked for .img.gz and .img.xz)"

# Determine decompression command from extension
decompress_cmd=""
ext=""
case "${img}" in
    *.gz) decompress_cmd="gzip -d"  ; ext=".gz" ;;
    *.xz) decompress_cmd="xz -d"   ; ext=".xz" ;;
    *)    _die "Unknown format: ${img}" ;;
esac

# ── Extract ───────────────────────────────────────────────────────────────
name="$(basename "${img}" "${ext}")"
dst="${dst_dir}/${name}"
mkdir -p "${dst_dir}"

if [[ -f "${dst}" ]]; then
    _die "Already exists: ${dst}"
fi

total="$(stat -c %s "${img}")"
_msg "Extracting: ${img##*/} → out_extract/${name}"

# Background the decompression and poll progress via bytes written to dst
${decompress_cmd} < "${img}" > "${dst}" &
pid=$!

while kill -0 "${pid}" 2>/dev/null; do
    if [[ -f "${dst}" ]]; then
        current="$(stat -c %s "${dst}" 2>/dev/null || echo 0)"
        printf "\r  %s / %s decompressed  " \
            "$(numfmt --to=iec-i --suffix=B "${current}")" \
            "$(numfmt --to=iec-i --suffix=B "${total}")"
    fi
    sleep 1
done

rc=0
wait "${pid}" || rc=$?
printf "\r                                                \r"
[[ ${rc} -eq 0 ]] || { rm -f "${dst}"; _die "Decompression failed (exit ${rc})"; }

_ok "${name} ($(du -h "${dst}" | cut -f1))"
