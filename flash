#!/bin/bash
# flash — Write an extracted .img to a block device with progress
set -euo pipefail

readonly PROGNAME="${0##*/}"
script_dir="$(cd "$(dirname "$0")" && pwd)"

src_dir="${script_dir}/out_extract"

# ── Colours ───────────────────────────────────────────────────────────────
if [[ -t 1 ]]; then
    B='\033[1m'; R='\033[0m'; RED='\033[1;31m'; GRN='\033[1;32m'; YLW='\033[1;33m'; CYN='\033[1;36m'
else
    B=''; R=''; RED=''; GRN=''; YLW=''; CYN=''
fi

_msg()  { printf "${CYN}[${PROGNAME}]${R} %s\n" "$*"; }
_ok()   { printf "${GRN}[${PROGNAME}] ✓${R} %s\n" "$*"; }
_warn() { printf "${YLW}[${PROGNAME}] !${R} %s\n" "$*" >&2; }
_die()  { printf "${RED}[${PROGNAME}] ✗${R} %s\n" "$*" >&2; exit 1; }

_usage() {
    cat <<EOF
${B}${PROGNAME}${R} — Flash an extracted image to a block device

${B}Usage:${R}
    ${PROGNAME} <image-name> <device>

${B}Example:${R}
    ${PROGNAME} archlinux-g5-ppc64-20260222 /dev/sdb
    ${PROGNAME} archlinux-g5-ppc64-20260222.img /dev/sdb

Writes out_extract/<image>.img to <device> using dd with progress.
Must be run as root (or with sudo).
EOF
    exit "${1:-0}"
}

# ── Argument parsing ──────────────────────────────────────────────────────
[[ $# -ge 2 ]] || _usage 1
[[ "$1" == "-h" || "$1" == "--help" ]] && _usage 0

input="$1"
device="$2"

# Resolve image path — allow with or without .img suffix
if [[ "${input}" == *.img ]]; then
    img="${src_dir}/${input}"
else
    img="${src_dir}/${input}.img"
fi

[[ -f "${img}" ]] || _die "Image not found: ${img}"
[[ -b "${device}" ]] || _die "Not a block device: ${device}"

# ── Safety checks ─────────────────────────────────────────────────────────
[[ $EUID -eq 0 ]] || _die "Must run as root"

# Refuse to write to mounted devices
if findmnt -rn -o SOURCE | grep -q "^${device}"; then
    _die "${device} has mounted partitions — unmount first"
fi

# Show device info for confirmation
_msg "Image:  ${img##*/} ($(du -h "${img}" | cut -f1))"
_msg "Device: ${device} ($(lsblk -dno SIZE "${device}" | xargs))"
lsblk -o NAME,SIZE,TYPE,MOUNTPOINTS "${device}" 2>/dev/null | sed 's/^/  /'
echo ""

read -rp "$(printf "${YLW}Write to ${device}? All data will be lost. [y/N]${R} ")" confirm
[[ "${confirm}" =~ ^[Yy]$ ]] || { _msg "Aborted."; exit 0; }

# ── Flash ─────────────────────────────────────────────────────────────────
_msg "Flashing..."

dd if="${img}" of="${device}" bs=4M status=progress conv=fsync

sync

_ok "Flashed ${img##*/} → ${device}"